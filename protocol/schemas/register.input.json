{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "match.register input",
  "type": "object",
  "required": ["protocol_version", "embedding", "city", "age_range", "intent"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "schelling-1.0"
    },
    "agent_model": {
      "type": "string",
      "description": "AI model used, e.g. 'claude-opus-4-6'"
    },
    "embedding_method": {
      "type": "string",
      "description": "How embedding was generated, e.g. 'anchor-rated'"
    },
    "embedding": {
      "type": "array",
      "items": { "type": "number", "minimum": -1, "maximum": 1 },
      "minItems": 50,
      "maxItems": 50
    },
    "city": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "age_range": {
      "type": "string",
      "enum": ["18-24", "25-34", "35-44", "45-54", "55-64", "65+"]
    },
    "intent": {
      "type": "array",
      "items": { "type": "string", "enum": ["friends", "romance", "collaborators"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "interests": {
      "type": "array",
      "items": { "type": "string", "maxLength": 100 },
      "maxItems": 20
    },
    "values_text": {
      "type": "string",
      "maxLength": 500
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "seeking": {
      "type": "string",
      "maxLength": 500
    },
    "identity": {
      "type": "object",
      "required": ["name", "contact"],
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" }
      }
    },
    "user_token": {
      "type": "string",
      "description": "Existing token for re-registration"
    }
  }
}
