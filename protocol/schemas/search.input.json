{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "match.search input",
  "type": "object",
  "required": ["user_token"],
  "properties": {
    "user_token": { "type": "string" },
    "top_k": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 },
    "threshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
    "intent_filter": { "type": "string", "enum": ["friends", "romance", "collaborators"] },
    "city_filter": { "type": "string" }
  }
}
