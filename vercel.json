{
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://schelling-protocol-production.up.railway.app/auth/:path*"
    },
    {
      "source": "/webhooks/:path*",
      "destination": "https://schelling-protocol-production.up.railway.app/webhooks/:path*"
    },
    {
      "source": "/schelling/:path*",
      "destination": "https://schelling-protocol-production.up.railway.app/schelling/:path*"
    },
    {
      "source": "/openapi.yaml",
      "destination": "https://schelling-protocol-production.up.railway.app/openapi.yaml"
    },
    {
      "source": "/health",
      "destination": "https://schelling-protocol-production.up.railway.app/health"
    },
    {
      "source": "/status",
      "destination": "https://schelling-protocol-production.up.railway.app/status"
    },
    {
      "source": "/.well-known/:path*",
      "destination": "https://schelling-protocol-production.up.railway.app/.well-known/:path*"
    },
    {
      "source": "/docs",
      "destination": "https://schelling-protocol-production.up.railway.app/docs"
    },
    {
      "source": "/robots.txt",
      "destination": "https://schelling-protocol-production.up.railway.app/robots.txt"
    },
    {
      "source": "/serendipity/setup",
      "destination": "https://schelling-protocol-production.up.railway.app/serendipity/setup"
    },
    {
      "source": "/serendipity",
      "destination": "https://schelling-protocol-production.up.railway.app/serendipity"
    },
    {
      "source": "/cards/setup",
      "destination": "https://schelling-protocol-production.up.railway.app/cards/setup"
    },
    {
      "source": "/cards/:slug/contact-setup",
      "destination": "https://schelling-protocol-production.up.railway.app/cards/:slug/contact-setup"
    },
    {
      "source": "/cards/:slug",
      "destination": "https://schelling-protocol-production.up.railway.app/cards/:slug"
    },
    {
      "source": "/cards",
      "destination": "https://schelling-protocol-production.up.railway.app/cards"
    },
    {
      "source": "/api/:path*",
      "destination": "https://schelling-protocol-production.up.railway.app/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "cleanUrls": true
}
