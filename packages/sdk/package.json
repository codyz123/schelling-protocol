{
  "name": "@schelling/sdk",
  "version": "3.0.0",
  "description": "TypeScript SDK for the Schelling Protocol — AI agent coordination layer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "schelling",
    "ai-agents",
    "coordination",
    "matchmaking",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codyz123/schelling-protocol.git",
    "directory": "packages/sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
