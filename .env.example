# Schelling Protocol — Environment Variables

# Server
SCHELLING_PORT=3000

# Database: sqlite (default) or postgres
DB_TYPE=sqlite

# Postgres (only if DB_TYPE=postgres)
# DATABASE_URL=postgres://schelling:schelling@postgres:5432/schelling
# POSTGRES_PASSWORD=schelling

# Playground mode — all operations work without credits/payment (default: true)
PLAYGROUND_MODE=true
